# ── LLM Provider (use one of the two below) ──────────────────────────────────

# Option A: Anthropic (direct)
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-20250514

# Option B: OpenRouter (fallback — use any model available on openrouter.ai)
# Leave ANTHROPIC_API_KEY empty and fill these in instead.
# Get key at: https://openrouter.ai/keys
# Model list: https://openrouter.ai/models
# Recommended: anthropic/claude-sonnet-4 or mistralai/mistral-large
OPENROUTER_API_KEY=
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
OPENROUTER_MODEL=anthropic/claude-sonnet-4

# ── Telegram ──────────────────────────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=
ADMIN_TELEGRAM_ID=           # Your Telegram numeric user ID (for /status command)

# ── Tether WDK ───────────────────────────────────────────────────────────────
WDK_SEED_PHRASE=             # BIP-39 mnemonic. Generate: node -e "const {ethers}=require('ethers');console.log(ethers.Wallet.createRandom().mnemonic.phrase)"
WDK_ENCRYPTION_KEY=          # 32+ char string for AES-256 wallet storage encryption

# ── Chains ───────────────────────────────────────────────────────────────────
# Mainnet
POLYGON_RPC_URL=
ARBITRUM_RPC_URL=
TRON_RPC_URL=

# Testnet (set USE_TESTNET=true for demo/development)
USE_TESTNET=true
POLYGON_AMOY_RPC_URL=https://rpc-amoy.polygon.technology
ARBITRUM_SEPOLIA_RPC_URL=https://sepolia-rollup.arbitrum.io/rpc

# ── IPFS ─────────────────────────────────────────────────────────────────────
WEB3_STORAGE_TOKEN=          # From https://web3.storage
IPFS_DISABLED=false          # Set true to skip IPFS for local demo

# ── Round Config ─────────────────────────────────────────────────────────────
ROUND_DURATION_HOURS=24
ROUND_CRON=0 0 * * *
MATCHING_POOL_MINIMUM=500
MATCHING_POOL_BOOST_THRESHOLD=5000
SYBIL_WEIGHT_THRESHOLD=0.7
PROTOCOL_FEE_BPS=100

# ── Storage & Server ─────────────────────────────────────────────────────────
DB_PATH=./flow.db
DASHBOARD_PORT=3000
DASHBOARD_SECRET=
